# Frontend dev config. Copy to `.env` to override; `.env` is gitignored.
#
# The localhost API that `npm run dev` proxies /api to (no-docker dev flow). The SPA always calls
# the relative /api; this only points the Vite dev proxy at your running API. Default when unset:
# http://localhost:5214 (the API's `dotnet run` address). Change it if you run the API elsewhere.
VITE_API_PROXY_TARGET=http://localhost:5214
