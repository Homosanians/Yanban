# ---- Database ----
POSTGRES_PASSWORD=yanban_dev_password

# ---- Auth ----
# JWT signing secret, must be at least 32 bytes. Change this for any non-local deployment: anyone
# with it can mint valid access tokens for any user.
JWT_SECRET=dev-only-change-me-super-secret-signing-key-min-32-bytes-long

# ---- Object storage (MinIO / S3) ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ---- CORS ----
# One extra origin allowed to call the API cross-origin (staging/prod). Empty by default: the SPA is
# served same-origin through the proxy, so this is only for callers hitting the API direct.
CORS_ALLOWED_ORIGIN=

# ---- Email ----
# Confirmation-link base: the app's public origin the mail points browsers back to (the SPA, not
# the API). Set this to your real domain in production.
EMAIL_APP_BASE_URL=http://localhost:8080

# SMTP relay. Defaults target the bundled Mailpit sink (host `mailpit`, port 1025, no auth, no TLS;
# read the mail at http://localhost:8025). Point these at a real relay to actually send mail:
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_STARTTLS=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM_ADDRESS=no-reply@yanban.local
EMAIL_FROM_NAME=Yanban
